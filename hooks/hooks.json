{
  "description": "Two injection points: SessionStart routes once to the medium-matched skill (laws:code / laws:prompt / laws:prose); UserPromptSubmit re-engages the laws on every user message.",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/skill-router.sh\" session-start"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/skill-router.sh\" engage"
          }
        ]
      }
    ]
  }
}
