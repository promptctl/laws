{
  "description": "Skill-router: reminds the session to load the medium-matched skill (laws:code / laws:guidance / laws:prose) at prompt submit, before subagent spawns, and throttled after file reads.",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/skill-router.sh\" user-prompt"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/skill-router.sh\" read-post"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Task|Agent",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/skill-router.sh\" task-pre"
          }
        ]
      }
    ]
  }
}
