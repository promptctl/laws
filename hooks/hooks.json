{
  "UserPromptSubmit": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/skill-router.sh\" user-prompt"
        }
      ]
    }
  ],
  "PostToolUse": [
    {
      "matcher": "Read",
      "hooks": [
        {
          "type": "command",
          "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/skill-router.sh\" read-post"
        }
      ]
    }
  ],
  "PreToolUse": [
    {
      "matcher": "Task|Agent",
      "hooks": [
        {
          "type": "command",
          "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/skill-router.sh\" task-pre"
        }
      ]
    }
  ]
}
